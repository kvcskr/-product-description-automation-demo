    {
      "parameters": {
        "jsCode": "const root = $json;\n\nlet text =\n  root?.[0]?.content?.find(c => c.type === 'output_text')?.text\n  || root?.[0]?.content?.[0]?.text\n  || root?.[0]?.[0]?.content?.find(c => c.type === 'output_text')?.text\n  || root?.[0]?.[0]?.content?.[0]?.text\n  || '';\n\nif (!text) {\n  return [{ json: { error: 'Nie znalazłem pola text w odpowiedzi', raw: root } }];\n}\n\nconst lines = text\n  .split(/\\r?\\n/)\n  .map(l => l.trim())\n  .filter(Boolean);\n\nconst data = {};\nfor (const line of lines) {\n  const eq = line.indexOf('=');\n  if (eq === -1) continue;\n  const key = line.slice(0, eq).trim();\n  const value = line.slice(eq + 1).trim();\n  data[key] = value;\n}\n\nconst cechyKorzysci = (data.CECHY_KORZYSCI || '')\n  .split('|')\n  .map(s => s.trim())\n  .filter(Boolean)\n  .join('\\n');\n\nreturn [\n  {\n    json: {\n      nazwa_produktu: data.NAZWA_PRODUKTU || '',\n      firma: data.FIRMA || '',\n      krotki_opis: data.KROTKI_OPIS || '',\n      cechy_korzysci: cechyKorzysci,\n      kod_ean: data.KOD_EAN || '',\n      raw_text: text,\n    },\n  },\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1568, 0],
